# NeuroVerse Configuration
# Copy to .env and modify as needed

# Backend
NEUROVERSE_HOST=0.0.0.0
NEUROVERSE_PORT=8000
NEUROVERSE_LOG_LEVEL=INFO
NEUROVERSE_ENVIRONMENT_MODE=dev
NEUROVERSE_PERFORMANCE_MODE=demo
NEUROVERSE_TICK_INTERVAL_MS=500
NEUROVERSE_SESSION_DURATION_S=180
NEUROVERSE_DATA_DIR=./data
NEUROVERSE_MODELS_DIR=../models
NEUROVERSE_REPORTS_DIR=../reports
NEUROVERSE_HARDWARE_MODE=simulator
NEUROVERSE_HARDWARE_CLOSED_LOOP_ENABLED=false
NEUROVERSE_LSL_DEMO_STREAM_NAME=NeuroVerseSyntheticEEG
NEUROVERSE_LSL_DEMO_STREAM_TYPE=EEG
NEUROVERSE_MODEL_MODE=heuristic
NEUROVERSE_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Frontend
VITE_WS_URL=ws://localhost:8000/ws/neurostream
VITE_API_URL=http://localhost:8000
